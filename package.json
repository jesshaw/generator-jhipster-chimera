{
  "name": "generator-jhipster-chimera",
  "version": "2.1.9",
  "private": false,
  "description": "Description for Chimera",
  "keywords": [
    "yeoman-generator",
    "jhipster-blueprint",
    "jhipster-8"
  ],
  "license": "MIT",
  "bin": {
    "jhipster-chimera": "dist/cli/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && copyfiles -u 1 \"generators/**/*.{ejs,ico,png,jpg,jpeg,svg,webp,css,woff2,java}\" dist/generators/",
    "ejslint": "ejslint generators/**/*.ejs",
    "lint": "eslint",
    "lint-fix": "npm run ejslint && npm run lint -- --fix",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "prettier-check": "prettier --check \"{,**/}*.{md,json,yml,html,cjs,mjs,js,cts,mts,ts,tsx,css,scss,vue,java}\"",
    "prettier-format": "prettier --write \"{,**/}*.{md,json,yml,html,cjs,mjs,js,cts,mts,ts,tsx,css,scss,vue,java}\"",
    "pretest": "npm run prettier-check && npm run lint && tsc",
    "test": "vitest run",
    "update-snapshot": "vitest run --update",
    "vitest": "vitest"
  },
  "dependencies": {
    "generator-jhipster": "9.1.0"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "ejs-lint": "2.0.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "yeoman-test": ">=10"
  },
  "engines": {
    "generator-jhipster": "9.1.0",
    "node": "^22.18.0 || >=24.11.0"
  },
  "export": {
    "./generators/*": {
      "types": "./dist/types/generators/*/index.d.ts",
      "import": "./dist/generators/*/index.js"
    }
  }
}
